{:paths ["src" "resources"]

 :deps {io.github.slagyr/isaac-foundation {:git/url "https://github.com/slagyr/isaac-foundation.git"
 :git/tag "v0.1.0" :git/sha "6dfd61831dae266d91ec667dead4b5fe99e16694"}
        cheshire/cheshire                 {:mvn/version "5.13.0"}
        clj-commons/clj-yaml              {:mvn/version "1.0.29"}
        com.cleancoders.c3kit/apron       {:mvn/version "3.0.0"}
        org.babashka/http-client          {:mvn/version "0.4.22"}
        org.clojure/tools.cli             {:mvn/version "1.1.230"}}

 :aliases
 {:dev-local {:override-deps {io.github.slagyr/isaac-foundation           {:local/root "../isaac-foundation"}
                               io.github.slagyr/isaac-foundation-spec      {:local/root "../isaac-foundation/spec"}
                               marigold.bridge/marigold.bridge             {:local/root "../isaac-foundation/modules/marigold.bridge"}
                               marigold.longwave/marigold.longwave         {:local/root "../isaac-foundation/modules/marigold.longwave"}}}

  :test {:extra-paths ["spec" "test-resources"]
         :extra-deps  {io.github.slagyr/isaac-foundation-spec {:git/url "https://github.com/slagyr/isaac-foundation.git"
 :git/tag "v0.1.0" :git/sha "6dfd61831dae266d91ec667dead4b5fe99e16694"
                                                                 :deps/root "spec"}
                       speclj/speclj                          {:mvn/version "3.13.0"}
                       babashka/process                       {:mvn/version "0.5.22"}
                       io.github.slagyr/gherclj               {:git/tag "v1.3.0" :git/sha "9c3bb1d"}
                       io.github.cleancoders/c3kit-wire       {:git/tag "2.5.1" :git/sha "1fae444"}
                       org.babashka/http-client               {:mvn/version "0.4.22"}
                       marigold.bridge/marigold.bridge        {:git/url "https://github.com/slagyr/isaac-foundation.git"
