{:id :isaac.agent,
 :version "0.1.15",
 :builtin? true,
 :factory isaac.agent.module/create-module,
 :berths
 #:isaac.agent{:tools
               {:description "LLM tool factories.",
                :schema
                {:type :map,
                 :key-spec {:type :keyword},
                 :value-spec
                 {:type :map,
                  :factory isaac.tool.registry/register-tool-entry!,
                  :schema
                  {:factory
                   {:type :symbol, :validations [:present?]}}}}},
               :llm-api
               {:description
                "LLM API factories — adapters per provider API (messages, chat-completions, ollama, ...).",
                :schema
                {:type :map,
                 :key-spec {:type :keyword},
                 :value-spec
                 {:type :map,
                  :factory isaac.llm.api.protocol/register-api-entry!,
                  :schema
                  {:factory
                   {:type :symbol, :validations [:present?]}}}}},
               :slash-commands
               {:description
                "Slash commands installed into the bridge slash registry.",
                :schema
                {:type :map,
                 :key-spec {:type :keyword},
                 :value-spec
                 {:type :map,
                  :factory isaac.slash.registry/register-slash-entry!,
                  :schema
                  {:factory
                   {:type :symbol, :validations [:present?]}}}}},
               :provider
               {:description
                "Materialized LLM providers — instances usable by models. Manifest contributions are third-party modules shipping a ready-to-use provider; user-instantiated providers in the [:providers] config slot also count toward this berth (see `[:registered-in? :isaac.agent/provider [:providers]]` use sites).",
                :schema
                {:type :map,
                 :key-spec {:type :keyword},
                 :value-spec {:type :map}}},
               :provider-template
               {:description
                "Provider templates — partial provider configs that user-config :providers entries can inherit from via :type.",
                :schema
                {:type :map,
                 :key-spec {:type :keyword},
                 :value-spec
                 {:type :map, :schema {:template {:type :map}}}}}},
 :isaac/cli
 {:auth
  {:usage "auth <subcommand> [options]",
   :summary "Manage authentication credentials",
   :namespace isaac.llm.auth.cli},
  :crew
  {:usage "crew [subcommand] [options]",
   :summary "Manage configured crew members",
   :namespace isaac.crew.cli},
  :prompt
  {:usage "prompt -m <message> [options]",
   :summary "Run a single prompt turn and exit",
   :namespace isaac.bridge.prompt-cli},
  :sessions
  {:usage "sessions [subcommand] [options]",
   :summary "Manage stored conversation sessions",
   :namespace isaac.session.cli}},
 :isaac.agent/llm-api
 {:messages {:factory isaac.llm.api.messages/make},
  :grover {:factory isaac.llm.api.grover/make},
  :ollama {:factory isaac.llm.api.ollama/make},
  :claude-cli {:factory isaac.llm.api.claude-cli/make},
  :chat-completions {:factory isaac.llm.api.chat-completions/make},
  :responses {:factory isaac.llm.api.responses/make}},
 :isaac.agent/tools
 {:web_fetch {:factory isaac.tool.builtin/web-fetch-tool-factory},
  :read {:factory isaac.tool.builtin/read-tool-factory},
  :exec {:factory isaac.tool.builtin/exec-tool-factory},
  :session_model
  {:factory isaac.tool.builtin/session-model-tool-factory},
  :grep {:factory isaac.tool.builtin/grep-tool-factory},
  :edit {:factory isaac.tool.builtin/edit-tool-factory},
  :multi_edit {:factory isaac.tool.builtin/multi-edit-tool-factory},
  :memory_write
  {:factory isaac.tool.builtin/memory-write-tool-factory},
  :web_search {:factory isaac.tool.builtin/web-search-tool-factory},
  :session_info
  {:factory isaac.tool.builtin/session-info-tool-factory},
  :write {:factory isaac.tool.builtin/write-tool-factory},
  :glob {:factory isaac.tool.builtin/glob-tool-factory},
  :memory_search
  {:factory isaac.tool.builtin/memory-search-tool-factory},
  :load_skill {:factory isaac.tool.skill/load-skill-tool-factory},
  :list_skills {:factory isaac.tool.skill/list-skills-tool-factory},
  :memory_get {:factory isaac.tool.builtin/memory-get-tool-factory},
  :comm_send {:factory isaac.tool.comm-send/comm-send-tool-factory}},
 :isaac.agent/provider-template
 {:anthropic
  {:template
   {:api "messages",
    :base-url "https://api.anthropic.com",
    :auth "api-key"}},
  :xai
  {:template
   {:api "chat-completions",
    :base-url "https://api.x.ai/v1",
    :auth "api-key"}},
  :grover {:template {:api "grover", :auth "none"}},
  :ollama
  {:template
   {:api "ollama", :base-url "http://localhost:11434", :auth "none"}},
  :openai
  {:template
   {:api "chat-completions",
    :base-url "https://api.openai.com/v1",
    :auth "api-key"}},
  :chatgpt
  {:template
   {:api "responses",
    :base-url "https://chatgpt.com/backend-api/codex",
    :auth "oauth-device",
    :oauth {:issuer "https://auth.openai.com"
            :client-id "app_EMoamEEZ73f0CkXaXp7hrann"
            :device-path "/api/accounts/deviceauth/usercode"
            :poll-path "/api/accounts/deviceauth/token"
            :token-path "/oauth/token"
            :redirect-uri "https://auth.openai.com/deviceauth/callback"
            :verification-url "https://auth.openai.com/codex/device"
            :flow :openai-device-auth
            :originator "isaac"
            :chatgpt-account-id? true
            :token-exchange {:requested-token "openai-api-key"
                             :subject-token-type "urn:ietf:params:oauth:token-type:id_token"}}}}
  :claude
  {:template
   {:api "claude-cli",
    :auth "none",
    :command "claude",
    :stream-supports-tool-calls false}}
  :grok
  {:template
   {:api "chat-completions",
    :base-url "https://api.x.ai/v1",
    :auth "oauth-device",
    :oauth {:issuer "https://auth.x.ai"
            :client-id "b1a00492-073a-47ea-816f-4c329264a828"
            :device-path "/oauth2/device/code"
            :token-path "/oauth2/token"
            :verification-url "https://accounts.x.ai/oauth2/device"
            :flow :oidc-device-code
            :scope "api:access offline_access"}}}},
 :isaac.agent/slash-commands
 {:crew {:factory isaac.slash.builtin/crew-command},
  :cwd {:factory isaac.slash.builtin/cwd-command},
  :effort {:factory isaac.slash.builtin/effort-command},
  :model {:factory isaac.slash.builtin/model-command},
  :status {:factory isaac.slash.builtin/status-command}},
 :isaac.config/schema
 {:providers
  {:entity-dir "providers",
   :merge-root-entity? true,
   :schema
   {:name "provider table",
    :type :map,
    :snapshot-only? true,
    :description
    "Provider configurations (map of id -> provider config)",
    :key-spec {:type :string},
    :value-spec
    {:name :provider,
     :type :map,
     :dynamic-schema
     {:berth :isaac.agent/provider-template, :path [:schema]},
     :schema
     {:effort
      {:type :int,
       :description "Effort level for this provider (0-10)"},
      :assistant-base-url
      {:type :string, :description "Base URL for assistant endpoints"},
      :supports-system-role
      {:type :boolean,
       :description
       "Whether the provider accepts a system role message"},
      :api
      {:type :id,
       :description
       "Provider API adapter (e.g. \"anthropic\", \"ollama\")",
       :validations [[:registered-in? :isaac.agent/llm-api]]},
      :name {:type :string, :description "Display name"},
      :response-format
      {:type :string, :description "Response format hint"},
      :type
      {:type :id,
       :description "Manifest provider id to inherit template from",
       :validations
       [[:registered-in? :isaac.agent/provider-template]]},
      :auth
      {:type :string,
       :description "Authentication mode (e.g. \"oauth-device\")"},
      :base-url {:type :string, :description "API base URL"},
      :headers
      {:type :map,
       :description "Extra HTTP headers to include in requests",
       :key-spec {:type :string},
       :value-spec {:type :string}},
      :oauth
      {:type :map,
       :description "OAuth device-code/provider descriptor metadata",
       :schema {:issuer {:type :string}
                :client-id {:type :string}
                :device-path {:type :string}
                :poll-path {:type :string}
                :token-path {:type :string}
                :redirect-uri {:type :string}
                :verification-url {:type :string}
                :flow {:type :keyword}
                :scope {:type :string}
                :originator {:type :string}
                :chatgpt-account-id? {:type :boolean}
                :token-exchange {:type :map
                                 :schema {:requested-token {:type :string}
                                          :subject-token-type {:type :string}}}}},
      :token
      {:type :string,
       :description "Authentication token (alias for api-key)"},
      :models
      {:type :seq,
       :description "Canonical model ids served by this provider",
       :spec {:type :string}},
      :auth-key {:type :string, :description "Authentication key"},
      :history-retention
      {:type :keyword,
       :description
       "Transcript history retention policy for sessions created against this provider",
       :validations [[:one-of? :prune :retain]]},
      :id
      {:type :id,
       :description "Provider id; must match filename when present"},
      :stream-supports-tool-calls
      {:type :boolean,
       :description "Whether streaming mode supports tool calls"},
      :stream-non-tool-turns
      {:type :boolean,
       :description "Use chat-stream for turns without tools (claude-cli)"},
      :command
      {:type :string,
       :description "CLI binary path for claude-cli shell-out"},
      :extra-args
      {:type :seq,
       :description "Extra CLI args forwarded before the prompt (claude-cli)",
       :spec {:type :string}},
      :compaction
      {:type :map,
       :description "Compaction policy override for this provider",
       :schema
       {:async? {:type :boolean},
        :head
        {:type :double,
         :validations
         [[:percentage? "e.g. 0.3 for 30% of context-window"]]},
        :head-threshold
        {:type :ignore,
         :description "Derived: head must stay below threshold",
         :validations [[:less-than? :head :threshold]]},
        :strategy
        {:type :keyword,
         :validations [[:one-of? :rubberband :slinky]]},
        :threshold
        {:type :double,
         :validations
         [[:percentage? "e.g. 0.8 for 80% of context-window"]]}}},
      :originator
      {:type :string, :description "X-Originator header value"},
      :api-key
      {:type :string,
       :description "API key",
       :validations [[:present-when? :auth "api-key"]]}}}}},
  :skill-menu-threshold
  {:schema
   {:type :int,
    :description
    "Max skill count to inject into the cached prompt before falling back to list_skills",
    :validations [:non-negative?]}},
  :tools
  {:schema
   {:type :map,
    :description "Tool configuration (per-tool config maps and global defaults)",
    :schema
    {:defaults
     {:type :map,
      :description "Global tool output caps applied at the turn boundary",
      :schema
      {:max-lines
       {:type :int,
        :description "Max lines in a tool result string before head-tail truncation"},
       :max-bytes
       {:type :int,
        :description "Max UTF-8 bytes in a tool result string before head-tail truncation"}}}
     :web_search
     {:type :map,
      :description "Web search tool config",
      :schema
      {:provider {:type :keyword, :validations [[:one-of? :brave]]},
       :api-key {:type :string, :validations [:present?]}}}}}},
  :crew
  {:entity-dir "crew",
   :frontmatter? true,
   :merge-root-entity? true,
   :companion {:field :soul, :mode :exclusive},
   :schema
   {:name "crew table",
    :type :map,
    :snapshot-only? true,
    :description
    "Crew member configurations (map of id -> crew config)",
    :key-spec {:type :string},
    :value-spec
    {:name :crew,
     :type :map,
     :schema
     {:tags
      {:type :ignore,
       :set-type? true,
       :description
       "Flat set of keyword tags for discovery and routing",
       :validations [:keyword-set?]},
      :effort
      {:type :int,
       :description
       "Effort level override for this crew member (0-10)"},
      :tools
      {:name :tools,
       :type :map,
       :description "Tool configuration",
       :schema
       {:allow
        {:type :seq,
         :description "Allowed tool names",
         :spec
         {:type :keyword,
          :validations [[:registered-in? :isaac.agent/tools]]}},
        :directories
        {:type :seq,
         :description
         "Extra allowed directories beyond crew quarters and the session role workspace; :role and :cwd expand to session cwd, strings are absolute paths",
         :spec {:type :ignore, :validations [:cwd-or-path?]}}}},
      :cwd
      {:type :string,
       :description "Default workdir for new sessions on this crew",
       :validations [:absolute-path?]},
      :soul
      {:type :string,
       :description
       "The personality of this crew member. Alternatively saved at config/crew/<id>.md"},
      :history-retention
      {:type :keyword,
       :description
       "Transcript history retention policy for new sessions",
       :validations [[:one-of? :prune :retain]]},
      :id
      {:type :id,
       :description
       "Crew member id; must match filename when present"},
      :context-mode
      {:type :keyword,
       :description "How much transcript history to replay each turn",
       :validations [[:one-of? :full :reset]]},
      :provider
      {:type :id,
       :description "Provider id for direct provider/model crews",
       :validations
       [[:registered-in? :isaac.agent/provider [:providers]]]},
      :compaction
      {:type :map,
       :schema
       {:async? {:type :boolean},
        :head
        {:type :double,
         :validations
         [[:percentage? "e.g. 0.3 for 30% of context-window"]]},
        :head-threshold
        {:type :ignore,
         :description "Derived: head must stay below threshold",
         :validations [[:less-than? :head :threshold]]},
        :strategy
        {:type :keyword,
         :validations [[:one-of? :rubberband :slinky]]},
        :threshold
        {:type :double,
         :validations
         [[:percentage? "e.g. 0.8 for 80% of context-window"]]}}},
      :max-in-flight
      {:type :int,
       :description
       "Maximum concurrent in-flight turns for this crew member",
       :validations [:positive?]},
      :tool-loop-max
      {:type :int,
       :description
       "Tool-call cycle budget for turns on this crew (default 100)",
       :validations [:positive?]},
      :model
      {:type :id,
       :description "ID of the model this crew member uses.",
       :validations [:model-exists?]}}}}},
  :prompt-paths
  {:schema
   {:type :seq,
    :description "Extra roots to scan for prepared prompts",
    :spec {:type :string}}},
  :defaults
  {:schema
   {:name :defaults,
    :type :map,
    :description "Default crew and model selections",
    :schema
    {:compaction
     {:type :map,
      :description "Default compaction policy for sessions",
      :schema
      {:async? {:type :boolean},
       :head
       {:type :double,
        :validations
        [[:percentage? "e.g. 0.3 for 30% of context-window"]]},
       :head-threshold
       {:type :ignore,
        :description "Derived: head must stay below threshold",
        :validations [[:less-than? :head :threshold]]},
       :strategy
       {:type :keyword, :validations [[:one-of? :rubberband :slinky]]},
       :threshold
       {:type :double,
        :validations
        [[:percentage? "e.g. 0.8 for 80% of context-window"]]}}},
     :context-mode
     {:type :keyword,
      :description "Default transcript replay mode for new turns",
      :validations [[:one-of? :full :reset]]},
     :crew
     {:type :id,
      :default "main",
      :description "Default crew member id",
      :validations [:crew-exists?]},
     :effort
     {:type :int,
      :description
      "Default effort level (0-10) when not overridden by provider/model/crew/session"},
     :history-retention
     {:type :keyword,
      :description
      "Default transcript history retention policy for new sessions",
      :validations [[:one-of? :prune :retain]]},
     :model
     {:type :id,
      :default "llama",
      :description "Default model alias",
      :validations [:model-exists?]},
     :provider-retry-after-ms
     {:type :int,
      :default 1800000,
      :description
      "Default retry-after (ms) when a provider wall has no Retry-After header"},
     :provider-auth-retry-ms
     {:type :int,
      :default 300000,
      :description
      "Default retry-after (ms) when a provider auth failure blocks a turn"}}}},
  :attention
  {:schema
   {:name :attention,
    :type :map,
    :description "System-scoped attention routing for operator outages",
    :schema
    {:notify
     {:type :map,
      :description "Default notification channel for system-scoped attention",
      :schema
      {:comm {:type :string, :description "Comm id to deliver attention messages"},
       :target {:type :string, :description "Comm-specific target (channel, user, etc.)"}}},
     :break-glass
     {:type :map,
      :description "Break-glass attention channel (declared; unused in 5a4n)",
      :schema
      {:comm {:type :string},
       :target {:type :string}}}}}},
  :skill-paths
  {:schema
   {:type :seq,
    :description "Extra typed roots to scan for prepared skills",
    :spec {:type :string}}},
  :models
  {:entity-dir "models",
   :merge-root-entity? true,
   :schema
   {:name "model table",
    :type :map,
    :snapshot-only? true,
    :description "Model configurations (map of id -> model config)",
    :key-spec {:type :string},
    :value-spec
    {:name :model,
     :type :map,
     :schema
     {:effort
      {:type :int,
       :description "Effort level override for this model (0-10)"},
      :thinking-budget-max
      {:type :int,
       :description
       "Anthropic: max thinking budget tokens at effort=10; scales linearly. Default 32000."},
      :allows-effort
      {:type :boolean,
       :description
       "Whether to attach :effort to requests for this model (default true)"},
      :history-retention
      {:type :keyword,
       :description
       "Transcript history retention policy for sessions created against this model",
       :validations [[:one-of? :prune :retain]]},
      :id
      {:type :id,
       :description "Model alias; must match filename when present"},
      :provider
      {:type :id,
       :description "Provider alias",
       :validations
       [:present?
        [:registered-in? :isaac.agent/provider [:providers]]],
       :required? true},
      :context-window
      {:type :int, :description "Context window size in tokens"},
      :think-mode
      {:type :keyword,
       :description
       "Ollama: how :effort is translated. :bool (default) → think true/false; :levels → \"low\"|\"medium\"|\"high\"."},
      :compaction
      {:type :map,
       :description "Compaction policy override for this model",
       :schema
       {:async? {:type :boolean},
        :head
        {:type :double,
         :validations
         [[:percentage? "e.g. 0.3 for 30% of context-window"]]},
        :head-threshold
        {:type :ignore,
         :description "Derived: head must stay below threshold",
         :validations [[:less-than? :head :threshold]]},
        :strategy
        {:type :keyword,
         :validations [[:one-of? :rubberband :slinky]]},
        :threshold
        {:type :double,
         :validations
         [[:percentage? "e.g. 0.8 for 80% of context-window"]]}}},
      :model
      {:type :string,
       :description "Provider-specific model name or id",
       :validations [:present?],
       :required? true}}}}},
  :command-paths
  {:schema
   {:type :seq,
    :description "Extra typed roots to scan for prepared commands",
    :spec {:type :string}}},
  :frequencies
  {:schema
   {:name :frequencies,
    :type :map,
    :description
    "Session frequencies map (selection + override); shared by CLI, hail, cron, and config consumers",
    :schema
    {:session
     {:type :seq,
      :description "Explicit session id(s)",
      :spec {:type :string}},
     :session-tags
     {:type :seq,
      :description "Tags sessions must carry (AND)",
      :spec {:type :keyword}},
     :crew
     {:type :string,
      :description "Sessions whose :crew matches this id"},
     :reach
     {:type :keyword,
      :description "How many sessions to target",
      :validations [[:one-of? :one :all]]},
     :prefer
     {:type :keyword,
      :description "Multi-match tiebreak when :reach is :one",
      :validations [[:one-of? :recent :oldest]]},
     :create
     {:type :keyword,
      :description "Create policy: :never, :if-missing, or :always",
      :validations [[:one-of? :never :if-missing :always]]},
     :with-crew
     {:type :string,
      :description "Override crew for this turn"},
     :with-model
     {:type :string,
      :description "Override model for this turn"},
     :with-effort
     {:type :int,
      :description "Override effort for this turn"},
     :with-context-mode
     {:type :keyword,
      :description "Override context mode for this turn"}}}}
  :sessions
  {:schema
   {:name :sessions,
    :type :map,
    :description "Session storage configuration",
    :schema
    {:naming-strategy
     {:type :ignore,
      :description "Session naming strategy",
      :validations [:keyword-or-string?]},
     :store
     {:type :keyword,
      :description
      "Session store implementation: :memory, :jsonl-edn-sidecar (default), :jsonl-edn-index"}}}},
  :prompt-dir-names
  {:schema
   {:type :map,
    :description
    "Directory-name to prompt-type mapping for prepared prompts",
    :key-spec {:type :string},
    :value-spec {:type :string}}}},

 :isaac.config/check
 {:comm-reserved-schema
  {:fn isaac.config.checks/check-comm-reserved-schema},
  :crew-broad-directories
  {:fn isaac.config.checks/check-crew-broad-directories},
  :manifest-refs {:fn isaac.config.checks/check-manifest-refs},
  :resolved-providers
  {:fn isaac.config.checks/check-resolved-providers}}}
